
{
  "entities": {
    "Property": {
      "title": "Property",
      "description": "Represents a managed real estate asset",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the property" },
        "address": { "type": "string", "description": "Location address" },
        "type": { "type": "string", "enum": ["residential", "commercial"], "description": "Category of the property" },
        "units": { "type": "number", "description": "Total number of units" },
        "occupiedUnits": { "type": "number", "description": "Number of currently rented units" },
        "monthlyIncome": { "type": "number", "description": "Total monthly revenue in SAR" },
        "imageUrl": { "type": "string", "format": "uri", "description": "Reference image for the building" }
      },
      "required": ["name", "address", "type", "units"]
    },
    "Tenant": {
      "title": "Tenant",
      "description": "Detailed information about a tenant including financial standing",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "phone": { "type": "string", "description": "Contact number" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "status": { "type": "string", "enum": ["active", "warning", "inactive"], "description": "Current standing" },
        "balance": { "type": "number", "description": "Current financial balance" },
        "accumulatedDebt": { "type": "number", "description": "Total debt from previous periods" },
        "securityDeposit": { "type": "number", "description": "Refundable security deposit amount" },
        "rentalType": { "type": "string", "enum": ["advance", "arrears"], "description": "Whether rent is paid in advance or arrears" },
        "waterBill": { "type": "number", "description": "Current water service balance" },
        "electricityBill": { "type": "number", "description": "Current electricity service balance" },
        "propertyId": { "type": "string", "description": "ID of the property" },
        "unitId": { "type": "string", "description": "Specific unit ID" },
        "avatarUrl": { "type": "string", "format": "uri" }
      },
      "required": ["name", "phone", "status", "unitId"]
    },
    "Contract": {
      "title": "Contract",
      "description": "Legal rental agreement",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "propertyId": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "rentAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "expired", "pending"] }
      },
      "required": ["tenantId", "propertyId", "startDate", "endDate", "rentAmount"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "tenantName": { "type": "string" },
        "propertyId": { "type": "string" },
        "propertyName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "method": { "type": "string", "enum": ["bank_transfer", "mada", "check", "cash"] },
        "status": { "type": "string", "enum": ["paid", "pending", "failed"] },
        "receiptNo": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["tenantName", "amount", "date", "status"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/properties/{propertyId}": {
      "schema": "Property",
      "description": "Collection of all managed properties"
    },
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Collection of all registered tenants"
    },
    "/contracts/{contractId}": {
      "schema": "Contract",
      "description": "Archive of rental contracts"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Financial transactions ledger"
    }
  }
}
